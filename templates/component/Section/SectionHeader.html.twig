{%- set classes = html_classes(
    'flex flex-col gap-4 mb-4',
    'group-data-[size=lg]/section:mb-10',
    attributes.render('class')|default(''),
) -%}

{#- Template -#}

<div
    data-slot="section-header"
    class="{{ classes|tailwind_merge }}"
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</div>
